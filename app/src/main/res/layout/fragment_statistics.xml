<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.09">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✿" android:textSize="42sp"
            android:layout_gravity="top|end" android:layout_marginTop="20dp" android:layout_marginEnd="14dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❀" android:textSize="34sp"
            android:layout_gravity="top|start" android:layout_marginTop="70dp" android:layout_marginStart="12dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✾" android:textSize="26sp"
            android:layout_gravity="start|center_vertical" android:layout_marginStart="14dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❁" android:textSize="38sp"
            android:layout_gravity="end|center_vertical" android:layout_marginEnd="10dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✿" android:textSize="22sp"
            android:layout_gravity="center|start" android:layout_marginStart="50dp" android:layout_marginTop="400dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❀" android:textSize="30sp"
            android:layout_gravity="center|end" android:layout_marginEnd="28dp" android:layout_marginTop="350dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✾" android:textSize="20sp"
            android:layout_gravity="bottom|start" android:layout_marginBottom="240dp" android:layout_marginStart="30dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✿" android:textSize="28sp"
            android:layout_gravity="bottom|end" android:layout_marginBottom="200dp" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❁" android:textSize="18sp"
            android:layout_gravity="bottom|start" android:layout_marginBottom="100dp" android:layout_marginStart="70dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❀" android:textSize="24sp"
            android:layout_gravity="bottom|end" android:layout_marginBottom="70dp" android:layout_marginEnd="50dp" />
    </FrameLayout>

    <ScrollView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/statistics_title"
                android:textSize="26sp"
                android:textColor="?attr/colorSecondaryVariant"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cumulative_focus"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_total_times"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0" android:textSize="32sp"
                                android:textColor="?attr/colorSecondary" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/total_times" android:textSize="11sp"
                                android:textColor="@color/text_hint" android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="44dp" android:background="?attr/colorPrimaryLight" />
                        <LinearLayout
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_total_duration"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0h" android:textSize="32sp"
                                android:textColor="?attr/colorPrimaryVariant" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/total_duration" android:textSize="11sp"
                                android:textColor="@color/text_hint" android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="44dp" android:background="?attr/colorPrimaryLight" />
                        <LinearLayout
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_avg_daily"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0h" android:textSize="32sp"
                                android:textColor="?attr/colorSecondaryVariant" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/avg_daily" android:textSize="11sp"
                                android:textColor="@color/text_hint" android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="22dp" app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_bg" android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="每日签到" android:textSize="14sp"
                        android:textColor="@color/text_secondary" android:textStyle="bold"
                        android:layout_marginBottom="14dp" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_streak" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0" android:textSize="30sp"
                                android:textColor="?attr/colorSecondary" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="连续天数" android:textSize="11sp"
                                android:textColor="@color/text_hint" android:layout_marginTop="3dp" />
                        </LinearLayout>
                        <View android:layout_width="1dp" android:layout_height="40dp" android:background="?attr/colorPrimaryLight" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_total_checkins" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0" android:textSize="30sp"
                                android:textColor="?attr/colorPrimaryVariant" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="累计签到" android:textSize="11sp"
                                android:textColor="@color/text_hint" android:layout_marginTop="3dp" />
                        </LinearLayout>
                        <View android:layout_width="1dp" android:layout_height="40dp" android:background="?attr/colorPrimaryLight" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_weekly_focus" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0h" android:textSize="30sp"
                                android:textColor="?attr/colorSecondaryVariant" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="本周专注" android:textSize="11sp"
                                android:textColor="@color/text_hint" android:layout_marginTop="3dp" />
                        </LinearLayout>
                    </LinearLayout>
                    <TextView android:id="@+id/btn_check_in" android:layout_width="match_parent"
                        android:layout_height="46dp" android:layout_marginTop="14dp"
                        android:background="@drawable/bg_button_deep" android:gravity="center"
                        android:text="✅ 今日打卡签到" android:textColor="@color/white"
                        android:textSize="15sp" android:textStyle="bold"
                        android:elevation="4dp" android:clickable="true" android:focusable="true" />
                    <TextView android:id="@+id/tv_checked_in" android:layout_width="match_parent"
                        android:layout_height="46dp" android:layout_marginTop="14dp"
                        android:background="@drawable/bg_card_outlined" android:gravity="center"
                        android:text="🎉 今日已打卡" android:textColor="?attr/colorSecondaryVariant"
                        android:textSize="15sp" android:textStyle="bold" android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="22dp" app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_bg" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/today_focus"
                            android:textSize="14sp" android:textColor="@color/text_secondary" android:textStyle="bold" />
                        <TextView android:id="@+id/tv_today_date" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="" android:textSize="12sp"
                            android:textColor="@color/text_hint" android:background="@drawable/bg_chip_pink"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="3dp" android:paddingBottom="3dp" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_today_times" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0" android:textSize="28sp"
                                android:textColor="?attr/colorSecondary" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/total_times" android:textSize="11sp"
                                android:textColor="@color/text_hint" android:layout_marginTop="2dp" />
                        </LinearLayout>
                        <View android:layout_width="1dp" android:layout_height="38dp" android:background="?attr/colorPrimaryLight" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_today_duration" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0min" android:textSize="28sp"
                                android:textColor="?attr/colorPrimaryVariant" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/total_duration" android:textSize="11sp"
                                android:textColor="@color/text_hint" android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="22dp" app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_bg" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/focus_distribution"
                            android:textSize="14sp" android:textColor="@color/text_secondary" android:textStyle="bold" />
                        <RadioGroup android:id="@+id/rg_period" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:orientation="horizontal">
                            <RadioButton android:id="@+id/rb_day" style="@style/DistributionRadio"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:checked="true" android:text="@string/day" />
                            <RadioButton android:id="@+id/rb_week" style="@style/DistributionRadio"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/week" />
                            <RadioButton android:id="@+id/rb_month" style="@style/DistributionRadio"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="@string/month" />
                        </RadioGroup>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView android:id="@+id/btn_pie_prev" android:layout_width="32dp"
                            android:layout_height="32dp" android:gravity="center"
                            android:text="◀" android:textSize="14sp"
                            android:textColor="?attr/colorSecondary"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true" android:focusable="true" />
                        <TextView android:id="@+id/tv_pie_range" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="2026/05/25"
                            android:textSize="13sp" android:textColor="?attr/colorSecondary"
                            android:textStyle="bold" />
                        <TextView android:id="@+id/btn_pie_next" android:layout_width="32dp"
                            android:layout_height="32dp" android:gravity="center"
                            android:text="▶" android:textSize="14sp"
                            android:textColor="?attr/colorSecondary"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true" android:focusable="true" />
                    </LinearLayout>
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pie_chart" android:layout_width="match_parent"
                        android:layout_height="230dp" />
                    <TextView android:id="@+id/tv_pie_total" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="总计 0min"
                        android:textSize="13sp" android:textColor="@color/text_hint"
                        android:layout_gravity="center" android:layout_marginTop="8dp"
                        android:background="@drawable/bg_chip_pink"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="22dp" app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_bg" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView android:id="@+id/btn_tod_prev" android:layout_width="32dp"
                            android:layout_height="32dp" android:gravity="center"
                            android:text="◀" android:textSize="14sp"
                            android:textColor="?attr/colorSecondary"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true" android:focusable="true" />
                        <TextView android:id="@+id/tv_tod_label" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="今天"
                            android:textSize="13sp" android:textColor="?attr/colorSecondary"
                            android:textStyle="bold" />
                        <TextView android:id="@+id/btn_tod_next" android:layout_width="32dp"
                            android:layout_height="32dp" android:gravity="center"
                            android:text="▶" android:textSize="14sp"
                            android:textColor="?attr/colorSecondary"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true" android:focusable="true" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/layout_tod_heatmap"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" />
                    <LinearLayout android:id="@+id/layout_tod_legend"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="22dp" app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_bg" android:layout_marginBottom="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">
                        <TextView android:id="@+id/btn_bar_prev" android:layout_width="32dp"
                            android:layout_height="32dp" android:gravity="center"
                            android:text="◀" android:textSize="14sp"
                            android:textColor="?attr/colorSecondary"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true" android:focusable="true" />
                        <TextView android:id="@+id/tv_bar_month" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="2026年5月"
                            android:textSize="14sp" android:textColor="@color/text_secondary"
                            android:textStyle="bold" />
                        <TextView android:id="@+id/btn_bar_next" android:layout_width="32dp"
                            android:layout_height="32dp" android:gravity="center"
                            android:text="▶" android:textSize="14sp"
                            android:textColor="?attr/colorSecondary"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true" android:focusable="true" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:id="@+id/tv_bar_total" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="总计 0min"
                            android:textSize="11sp" android:textColor="@color/text_hint" />
                        <View android:layout_width="1dp" android:layout_height="18dp"
                            android:background="?attr/colorPrimaryLight" />
                        <TextView android:id="@+id/tv_bar_max" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="最高 -"
                            android:textSize="11sp" android:textColor="@color/text_hint" />
                        <View android:layout_width="1dp" android:layout_height="18dp"
                            android:background="?attr/colorPrimaryLight" />
                        <TextView android:id="@+id/tv_bar_avg" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:gravity="center" android:text="日均 0min"
                            android:textSize="11sp" android:textColor="@color/text_hint" />
                    </LinearLayout>
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/bar_chart" android:layout_width="match_parent"
                        android:layout_height="210dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
