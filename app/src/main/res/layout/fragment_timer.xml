<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.12">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✿" android:textSize="52sp"
            android:layout_gravity="top|end" android:layout_marginTop="14dp" android:layout_marginEnd="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❀" android:textSize="38sp"
            android:layout_gravity="top|start" android:layout_marginTop="60dp" android:layout_marginStart="12dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✾" android:textSize="44sp"
            android:layout_gravity="top|center_horizontal" android:layout_marginTop="100dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❁" android:textSize="34sp"
            android:layout_gravity="top|end" android:layout_marginTop="130dp" android:layout_marginEnd="40dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✿" android:textSize="28sp"
            android:layout_gravity="start|center_vertical" android:layout_marginStart="20dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❀" android:textSize="46sp"
            android:layout_gravity="end|center_vertical" android:layout_marginEnd="14dp" android:layout_marginTop="-40dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✾" android:textSize="30sp"
            android:layout_gravity="center|start" android:layout_marginStart="60dp" android:layout_marginTop="280dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✿" android:textSize="40sp"
            android:layout_gravity="center|end" android:layout_marginEnd="30dp" android:layout_marginTop="320dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❁" android:textSize="50sp"
            android:layout_gravity="center_horizontal" android:layout_marginTop="380dp" android:alpha="0.6" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✿" android:textSize="24sp"
            android:layout_gravity="bottom|start" android:layout_marginBottom="200dp" android:layout_marginStart="30dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❀" android:textSize="36sp"
            android:layout_gravity="bottom|start" android:layout_marginBottom="160dp" android:layout_marginStart="80dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✾" android:textSize="48sp"
            android:layout_gravity="bottom|end" android:layout_marginBottom="140dp" android:layout_marginEnd="20dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❁" android:textSize="22sp"
            android:layout_gravity="bottom|end" android:layout_marginBottom="220dp" android:layout_marginEnd="60dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✿" android:textSize="32sp"
            android:layout_gravity="bottom|center_horizontal" android:layout_marginBottom="100dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❀" android:textSize="26sp"
            android:layout_gravity="bottom|start" android:layout_marginBottom="60dp" android:layout_marginStart="50dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✾" android:textSize="20sp"
            android:layout_gravity="bottom|end" android:layout_marginBottom="70dp" android:layout_marginEnd="100dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="♡" android:textSize="18sp"
            android:layout_gravity="top|start" android:layout_marginTop="220dp" android:layout_marginStart="50dp" android:alpha="0.5" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✦" android:textSize="14sp"
            android:layout_gravity="end" android:layout_marginEnd="60dp" android:layout_marginTop="200dp" android:alpha="0.45" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="·" android:textSize="40sp"
            android:layout_gravity="start" android:layout_marginStart="40dp" android:layout_marginTop="180dp" android:alpha="0.3" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="·" android:textSize="35sp"
            android:layout_gravity="end" android:layout_marginEnd="25dp" android:layout_marginTop="360dp" android:alpha="0.3" />
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/timer_title"
                    android:textSize="26sp"
                    android:textColor="?attr/colorSecondaryVariant"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱"
                    android:textSize="30sp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/select_subject"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary" />

                        <Spinner
                            android:id="@+id/spinner_subject"
                            android:layout_width="160dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_input"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_custom_subject"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/pink_soft">

                            <EditText
                                android:id="@+id/et_custom_subject"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:hint="输入自定义科目…"
                                android:textColorHint="@color/text_hint"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:maxLines="1"
                                android:inputType="text" />
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:id="@+id/btn_confirm_custom"
                            android:layout_width="44dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_button_deep"
                            android:gravity="center"
                            android:text="✓"
                            android:textSize="18sp"
                            android:textColor="@color/white"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btn_delete_custom"
                            android:layout_width="44dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_card_outlined"
                            android:gravity="center"
                            android:text="✕"
                            android:textSize="16sp"
                            android:textColor="@color/text_hint"
                            android:clickable="true"
                            android:focusable="true"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="44dp"
                    android:paddingBottom="36dp"
                    android:background="@color/card_bg">

                    <TextView
                        android:id="@+id/tv_timer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/timer_idle"
                        android:textSize="64sp"
                        android:textColor="?attr/colorSecondaryVariant"
                        android:fontFamily="monospace"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_timer_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_chip_status"
                        android:visibility="gone"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/btn_start"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_button_deep"
                    android:gravity="center"
                    android:text="@string/start"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:elevation="6dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_pause"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:background="@drawable/bg_gradient_primary"
                    android:gravity="center"
                    android:text="@string/pause"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btn_stop"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_button_stop"
                    android:gravity="center"
                    android:text="@string/stop"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:elevation="4dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/pink_soft" />

                <TextView
                    android:id="@+id/tv_last_record"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="准备开始…"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/pink_soft" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
